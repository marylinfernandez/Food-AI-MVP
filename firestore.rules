rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * PANTRYPAL AI SECURITY RULES
     *
     * Core Philosophy:
     * This ruleset enforces a strict user-ownership model for all personal data (profiles, pantry stock, 
     * and interactions) while providing global read-only access to canonical food and kitchen metadata.
     *
     * Data Structure:
     * - User-specific data is stored at /users/{userId} and within its subcollections (/pantryItems, /recipeInteractions).
     * - Global, shared data (Ingredients, Recipes, Appliances, etc.) is stored in top-level collections.
     *
     * Key Security Decisions:
     * - Authorization Independence: User ownership is determined primarily by the document path wildcards ({userId}).
     * - Denormalization: Critical relational fields like 'userId' are enforced to match the path during creation.
     * - Read-Only Globals: Standard users cannot modify canonical data; these collections are managed by system admins or AI agents.
     * - Prototyping Flexibility: Logic enforces "Who" can access data, but does not strictly validate the "Shape" of the data.
     */

    // --- HELPER FUNCTIONS ---

    /** @description Checks if the user is authenticated with Firebase. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the authenticated user's UID matches the provided userId. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Verifies ownership and ensures the document exists before a write. */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    // --- COLLECTION RULES ---

    /**
     * @description Rules for user profiles. Document ID must match Auth UID.
     * @path /users/{userId}
     * @allow (create) User 'abc' creates document '/users/abc'.
     * @deny (create) User 'abc' attempts to create document '/users/xyz'.
     * @principle Path-based ownership and self-creation validation.
     */
    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);

      /**
       * @description User's personal inventory of food items.
       * @path /users/{userId}/pantryItems/{pantryItemId}
       * @allow (list) User 'abc' listing their own pantry items.
       * @deny (get) User 'abc' reading pantry items of user 'def'.
       * @principle Hierarchical ownership ensures data privacy within user silos.
       */
      match /pantryItems/{pantryItemId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Logs of how the user interacted with AI-suggested recipes.
       * @path /users/{userId}/recipeInteractions/{interactionId}
       * @allow (create) User 'abc' logs a new interaction with recipe 'r1'.
       * @deny (delete) User 'abc' tries to delete interaction logs for user 'xyz'.
       * @principle Path-based ownership with immutability for the relational link.
       */
      match /recipeInteractions/{interactionId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);
      }
    }

    /**
     * @description Canonical list of all food ingredients.
     * @path /ingredients/{ingredientId}
     * @allow (get) Any signed-in user reading ingredient data.
     * @deny (create) Any user attempting to add a new canonical ingredient.
     * @principle Publicly readable but restricted write access (system-managed).
     */
    match /ingredients/{ingredientId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if false;
    }

    /**
     * @description Global collection of recipes generated or curated by AI.
     * @path /recipes/{recipeId}
     * @allow (list) Any authenticated user browsing recipes.
     * @deny (update) A user attempting to modify a public recipe's instructions.
     * @principle Global availability for consumption with strict management controls.
     */
    match /recipes/{recipeId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if false;
    }

    /**
     * @description Master list of kitchen appliances supported by the app.
     * @path /appliances/{applianceId}
     * @allow (get) Signed-in user fetching appliance details.
     * @deny (write) Any user write operation.
     * @principle Read-only metadata collection.
     */
    match /appliances/{applianceId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if false;
    }

    /**
     * @description Global list of dietary restrictions (e.g., Vegan, Keto).
     * @path /dietaryRestrictions/{restrictionId}
     * @allow (get) Signed-in user reading definitions.
     * @principle Read-only metadata collection.
     */
    match /dietaryRestrictions/{restrictionId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if false;
    }

    /**
     * @description Global list of common food allergies.
     * @path /allergies/{allergyId}
     * @allow (list) Authenticated users listing available allergy tags.
     * @principle Read-only metadata collection.
     */
    match /allergies/{allergyId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if false;
    }

    /**
     * @description Global list of taste profiles and preferences.
     * @path /tastePreferences/{preferenceId}
     * @allow (get) Signed-in user viewing a taste preference.
     * @principle Read-only metadata collection.
     */
    match /tastePreferences/{preferenceId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if false;
    }
  }
}